# Cade Imoveis environment template.
# Copy to .env.local or pull from Vercel. Never commit real values.

# Required for the Next.js app.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Never expose as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Local scripts aliases used by scripts/seed-*.mjs and scripts/smoke-fluxos.mjs.
SUPA_URL=
ANON=
SROLE=

# Local operations.
SUPABASE_ACCESS_TOKEN=
GITHUB_TOKEN=
GH_TOKEN=

# Current support/content integrations.
OPENAI_API_KEY=
OPENAI_MODELO_SUPORTE=gpt-4o-mini
OPENAI_MODELO=gpt-5
IDEOGRAM_API_KEY=

# Hermes and future AI/marketing integrations.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
HERMES_API_URL=
HERMES_API_TOKEN=
PERPLEXITY_API_KEY=
PERPLEXITY_MODELO=sonar-pro
HIGGSFIELD_API_KEY=
HIGGSFIELD_ENDPOINT=flux-pro/kontext/max/text-to-image

# Planned optional integrations.
NEXT_PUBLIC_SENTRY_DSN=
RESEND_API_KEY=
